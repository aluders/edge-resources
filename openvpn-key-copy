copy local key to clipboard...

# from mac
ssh ubnt@router-ip "sudo cat /config/auth/secret9" | pbcopy

# from linux (requires xlip)
ssh ubnt@router-ip "sudo cat /config/auth/secret9" | xclip -selection clipboard

from uisp remote router terminal...

cat << 'EOF' | sudo tee /config/auth/secret9 > /dev/null
(enter for new line)
paste key
(enter for new line)
EOF
(enter to save)

# uap ssh reset...
syswrapper.sh restore-default
newer uap ssh reset...
set-default

# unvr ssh reset...
ubnt-systool reset2defaults

# manual ssh cloudkey update...
wget http://dl.ubnt.com/unifi/4.8.12/unifi_sysvinit_all.deb
dpkg -i unifi_sysvinit_all.deb
rm unifi_sysvinit_all.deb

# manual ssh firmware update on cloudkey...
In order to free up enough space to install I cleared the /tmp and /var/tmp directories and then did the following.
## CLEAN AUFS 
apt-get update
apt-get install aufs-tools
/sbin/auplink / flush
apt-get clean
cd /data
wget http://<URL>/somefirmware.bin
ubnt-systool fwupdate /data/somefirmware.bin

# unifi ssh firmware update example...
curl -O --insecure https://dl.ubnt.com/unifi/firmware/somefirmware.bin
mv somefirmware.bin /tmp/fwupdate.bin
syswrapper.sh upgrade2 &

# protect camera ssh firmware...
curl -o /tmp/fwupdate.bin http://fw-download.ubnt.com/data/uvc/63ae-sav530q-5.1.190-5c1b8b84-e767-4ffc-a698-dd5218e228af.bin
fwupdate -m

# protect camera ssh reset...
set-default

# enable unifi protect camera ssh...
# ssh to nvr

# run the following command
jq '.enableSsh=true' /etc/unifi-protect/config.json 2>/dev/null \
|| jq -n '{ enableSsh: true }' > /etc/unifi-protect/config.json

# then restart protect
systemctl restart unifi-protect

